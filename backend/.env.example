# NexusAI Backend Configuration Example

# Project Information
PROJECT_NAME="NexusAI Backend"
ENV=development # development, staging, production
DEBUG=true

# Security Settings
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=supersecretjwtkeyplaceholder
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database Configuration
# Use local connection details for running outside docker-compose
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexus_db
# For Docker environment:
# DATABASE_URL=postgresql://postgres:password@db:5432/nexus_db

# Cache & Message Broker (Redis)
REDIS_URL=redis://localhost:6379/0
# For Docker environment:
# REDIS_URL=redis://redis:6379/0

# CORS Allowed Origins (Comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
